# LLM endpoint for query rewriting (vLLM OpenAI-compatible API)
QUERY_REWRITE_LLM_ENDPOINT="http://localhost:8009"

## Chat History service endpoint (for contextualization)
# CHAT_HISTORY_ENDPOINT=http://localhost:6012

## Uncomment to change the microservice timeout (seconds)
#QUERY_REWRITE_TIMEOUT=240

## Uncomment to change the max concurrency
#QUERY_REWRITE_MAX_CONCURRENCY=8

## Uncomment to change the microservice port
#QUERY_REWRITE_USVC_PORT=6626

## Uncomment to change the microservice log level
#OPEA_LOGGER_LEVEL=INFO
