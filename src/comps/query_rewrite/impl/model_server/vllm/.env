## Provide your Hugging Face API key to enable access to Hugging Face models.
#HF_TOKEN=<your-hf-api-key>

## VLLM Model Server Settings For Query Rewriting ##
QUERY_REWRITE_VLLM_MODEL_NAME="AMead10/Llama-3.2-3B-Instruct-AWQ"
QUERY_REWRITE_VLLM_PORT=8009
CHAT_HISTORY_ENDPOINT=http://localhost:6012

## VLLM Settings ##
VLLM_QUANTIZATION=awq
VLLM_CPU_KVCACHE_SPACE=40
VLLM_DTYPE=bfloat16
VLLM_MAX_NUM_SEQS=256
VLLM_SKIP_WARMUP=false
VLLM_TP_SIZE=1
VLLM_PP_SIZE=1
VLLM_MAX_MODEL_LEN=4096
OMP_NUM_THREADS=32

## Proxy Settings – Uncomment if Needed ##
#NO_PROXY=
#HTTP_PROXY=
#HTTPS_PROXY=
