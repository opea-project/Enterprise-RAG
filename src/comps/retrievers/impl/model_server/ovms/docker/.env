## NER OVMS Model Server Settings
NER_OVMS_PORT=9001
NER_MODEL_NAME=tanaos/tanaos-NER-v1
NER_WEIGHT_FORMAT=int8  # Options: int8 (default, faster), fp32 (full precision)

## Retriever Microservice Settings
VECTOR_STORE=redis
REDIS_URL=redis://localhost:6379/0
METADATA_FILTERING_ENABLED=true
METADATA_EXTRACTION_MODE=hybrid # Options: hybrid, regex_only, ner_only
METADATA_LANGUAGE=en  # Language for regex patterns and name lemmatization ('en' or 'pl')

## Proxy Settings (for HuggingFace model downloads during container startup)
## Uncomment if your network requires a proxy to reach huggingface.co
## Used by optimum-cli export and hf_hub_download in entrypoint.sh / ner_gateway.py
#HTTP_PROXY=http://proxy.example.com:8080
#HTTPS_PROXY=http://proxy.example.com:8080
#NO_PROXY=localhost,127.0.0.1
