  "test_cases": [
    {
      "id": "en-001",
      "category": "author",
      "complexity": "simple",
      "prompt": "Show me reports by John Smith",
      "expected_extraction": {
        "author": {
          "value": "John Smith",
          "operator": "=="
        }
      },
      "expected_filter_python": "Text('author') == 'John Smith'",
      "expected_filter_string": "@author:{John Smith}"
    },
