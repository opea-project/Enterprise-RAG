  "test_cases": [
    {
      "id": "pl-001",
      "category": "author",
      "complexity": "simple",
      "prompt": "Pokaż mi raporty napisane przez Jana Kowalskiego",
      "expected_extraction": {
        "author": {
          "value": "Jan Kowalski",
          "operator": "=="
